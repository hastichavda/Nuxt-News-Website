"flex items-center text-xs font-semibold uppercase tracking-wide sm:text-sm\"\n        aria-label=\"Main\"\n      >\n        <NuxtLink\n          to=\"/news\"\n          class=\"rounded-full px-4 py-2 transition-all\"\n          :class=\"newsLinkClass\"\n        >\n          News\n        </NuxtLink>\n      </nav>\n    </div>\n  </header>\n</template>\n<script setup lang=\"ts\">\nconst route = useRoute()\nconst isScrolled = ref(false)\n\nconst handleScroll = () => {\n  isScrolled.value = window.scrollY > 10\n}\n\nconst newsLinkClass = computed(() =>\n  route.path.startsWith('/news')\n    ? 'bg-primary text-on-primary shadow-sm'\n    : 'text-muted hover:bg-muted/10 hover:text-on-surface',\n)\n\nonMounted(() => {\n  handleScroll()\n  window.addEventListener('scroll', handleScroll, { passive: true })\n})\n\nonBeforeUnmount(() => {\n  window.removeEventListener('scroll', handleScroll)\n})\n</script>\n","<template>\n  <footer class=\"mt-10 border-t border-border bg-surface\">\n    <div class=\"py-6 container-wide sm:py-8\">\n      <p class=\"text-sm text-center text-muted\">\n        © {{ year }} News. Starter layout.\n      </p>\n    </div>\n  </footer>\n</template>\n<script setup lang=\"ts\">\nconst year = new Date().getFullYear()\n</script>\n","<template>\n  <div class=\"flex min-h-screen flex-col overflow-x-hidden\">\n    <LayoutHeader />\n    <main class=\"min-w-0 flex-1\">\n      <Transition name=\"page-fade\" mode=\"out-in\">\n        <slot />\n      </Transition>\n    </main>\n    <LayoutFooter />\n  </div>\n</template>\n"],"version":3}